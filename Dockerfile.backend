FROM python:3.12-slim

WORKDIR /app

COPY packages/fleet-back/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY packages/fleet-back ./packages/fleet-back
WORKDIR /app/packages/fleet-back

EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:3001/')"

CMD ["python", "app.py"]
